# ============================================================
# lilibear-transcard · 本地环境变量模板
# 实际使用时复制为 .env，填入真实密钥；.env 不会进 git
# ============================================================

# —— 图像生成（gpt-image-2，OpenAI 兼容反代） ——
# 主路：token-recyclebin；备用回滚：dm-fox
IMAGE_API_KEY=sk-填入-image-key
IMAGE_UPSTREAM_URL=https://image.token-recyclebin.com/v1/images/edits
IMAGE_MODEL=gpt-image-2

# —— Gemini 3 Flash（入口审核：判 is_food） ——
# 从 https://aistudio.google.com/apikey 申请 free-tier
# 国内服务器无法直连 Google 时，走 OpenAI 兼容中转（修改 GEMINI_BASE_URL）
GEMINI_API_KEY=填入-gemini-key
GEMINI_MODEL=gemini-3-flash-preview
# 默认走 Google 官方 OpenAI 兼容端点；POST 路径为 {BASE}/chat/completions
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# 审核 fail-open 阈值：置信度低于此值的 not_food 放行
AUDIT_FAIL_OPEN_BELOW=0.5

# —— 服务监听 ——
# 本地开发用 :: 双栈；生产用 127.0.0.1 由 nginx 反代
BIND_HOST=::
PORT=18084
